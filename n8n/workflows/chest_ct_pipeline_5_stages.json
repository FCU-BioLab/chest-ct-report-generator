                                         "jsCode":  "const body = $json.body ?? $json;\n\nif (!body.case_id) throw new Error(\u0027Missing case_id\u0027);\nif (!body.input_path) throw new Error(\u0027Missing input_path\u0027);\nif (!body.model_path) throw new Error(\u0027Missing model_path\u0027);\n\nconst normalizePath = (value) =\u003e String(value).replace(/\\\\/g, \u0027/\u0027);\nconst repoRootRaw = body.repo_root ?? process.env.CHEST_CT_REPO_ROOT ?? \u0027\u0027;\nif (!repoRootRaw) throw new Error(\u0027Missing repo_root or CHEST_CT_REPO_ROOT\u0027);\n\nconst repoRoot = normalizePath(repoRootRaw);\nconst pythonExe = normalizePath(body.python_exe ?? process.env.CHEST_CT_PYTHON ?? `${repoRoot}/venv/Scripts/python.exe`);\nconst pipelineScript = normalizePath(`${repoRoot}/n8n/run_case_pipeline.py`);\nconst workDir = normalizePath(body.work_dir ? String(body.work_dir) : `${repoRoot}/n8n/runtime`);\n\nreturn [{\n  json: {\n    case_id: String(body.case_id),\n    input_path: normalizePath(body.input_path),\n    model_path: normalizePath(body.model_path),\n    repo_root: repoRoot,\n    python_exe: pythonExe,\n    pipeline_script: pipelineScript,\n    work_dir: workDir,\n    threshold: body.threshold !== undefined ? Number(body.threshold) : 0.5,\n    device: body.device ? String(body.device) : \u0027cuda\u0027,\n    use_llm: body.use_llm === true || String(body.use_llm).toLowerCase() === \u0027true\u0027\n  }\n}];"
                                     },
